# ═══════════════════════════════════════════════════
# HF PROJECTS — .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ═══════════════════════════════════════════════════

# ─── Hugging Face Account ───────────────────────
HF_TOKEN=hf_your_token_here
HF_USERNAME=your-hf-username

# ─── Model Names ────────────────────────────────
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
GENERATION_MODEL=gpt2
IMAGE_MODEL=google/vit-base-patch16-224
FINETUNE_BASE_MODEL=distilbert-base-uncased
FINETUNE_DATASET=imdb

# ─── Fine-tuning Hyper-params ───────────────────
OUTPUT_DIR=./04_fine_tuning/results
NUM_EPOCHS=3
BATCH_SIZE=16
LEARNING_RATE=2e-5
MAX_LENGTH=256
WARMUP_STEPS=200
WEIGHT_DECAY=0.01
USE_FP16=True

# ─── Text Generation ────────────────────────────
GEN_MAX_TOKENS=80
GEN_NUM_SEQ=3
GEN_TEMP=0.9
GEN_TOP_P=0.95
GEN_SAMPLE=True
GEN_REP_PEN=1.1

# ─── Dataset Paths ──────────────────────────────
CUSTOM_CSV_PATH=./03_custom_dataset/data/sample.csv
PROCESSED_PATH=./03_custom_dataset/data/processed
TOKENIZED_PATH=./03_custom_dataset/data/tokenized

# ─── Image Classification ───────────────────────
IMAGE_DIR=./05_image_classification/images
IMAGE_TOP_K=3

# ─── Gradio App ─────────────────────────────────
GRADIO_PORT=7860
GRADIO_SHARE=False
APP_TITLE=My HF Demo
